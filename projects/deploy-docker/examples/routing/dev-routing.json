{
  "schema_version": "1.0",
  "hosts": [
    {
      "host": "api.worldcliques.org",
      "routes": [
        {
          "path_prefix": "/",
          "to_service": "default-api-json",
          "mode": "api-json",
          "websocket": "pass_through"
        }
      ]
    },
    {
      "host": "worldcliques.org",
      "routes": [
        {
          "path_prefix": "/",
          "to_service": "default-html",
          "mode": "web-html",
          "websocket": "not_used"
        }
      ]
    }
  ],
  "wildcards": [
    {
      "pattern": "*.worldcliques.org",
      "to_service": "default-html"
    }
  ]
}

