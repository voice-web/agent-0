:80 {
	encode zstd gzip

	@api host api.worldcliques.org
	@web host worldcliques.org

	# API host: JSON-only stub (token auth + CORS baseline lives in the API container)
	handle @api {
		reverse_proxy default-api-json:8080

		# Proxy-level failures (upstream down / connection refused) are distinct from
		# upstream returning HTTP 404/500. Containers should handle their own 404/500.
		#
		# If you want Caddy to serve a default HTML error page on proxy-level failures,
		# simplest is to have Caddy `file_server` a mounted `/error.html` from the HTML
		# assets, or have Caddy `reverse_proxy` to the HTML container with a rewritten path.
		#
		# handle_errors {
		#   rewrite * /error.html
		#   reverse_proxy default-html:8080
		# }
	}

	# Web host: default HTML container (rotating globe landing + starfield error.html)
	handle @web {
		reverse_proxy default-html:8080

		# If upstream is down and you want a pretty error, consider the same
		# handle_errors approach as above (serve /error.html).
	}

	# Wildcard fallback for subdomains (matches "*.worldcliques.org" conceptually).
	# If you use a real wildcard DNS record for subdomains, Caddy can’t match it
	# as a hostname wildcard in all cases; keeping this as the “everything else”.
	handle {
		reverse_proxy default-html:8080
	}
}

