# Reference routing for oci-vm (host + path). Regenerated by scripts/up.sh when you run infra.
# Wildcard TLS: public Let's Encrypt needs DNS-01 for *.worldcliques.org; use WC_CADDY_TLS=internal for lab.

api.worldcliques.org {
	encode zstd gzip
	reverse_proxy default-api-json:8080
}

auth.worldcliques.org {
	encode zstd gzip
	reverse_proxy keycloak:8080
}

worldcliques.org, *.worldcliques.org {
	encode zstd gzip

	# /login* on apex + subdomains -> globe-landing (prefix stripped for asset paths)
	handle_path /login/* {
		reverse_proxy globe-landing:8080
	}
	handle_path /login {
		reverse_proxy globe-landing:8080
	}

	handle {
		reverse_proxy default-html:8080
	}
}
