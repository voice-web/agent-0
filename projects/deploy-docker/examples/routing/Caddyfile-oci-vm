# Reference routing for oci-vm (host + path). Regenerated by scripts/up.sh when you run infra.
# HTML vhosts: explicit names only (no *.worldcliques.org). Override list with WC_OCI_HTML_HOSTS.

api.worldcliques.org {
	encode zstd gzip
	reverse_proxy default-api-json:8080
}

auth.worldcliques.org {
	encode zstd gzip
	reverse_proxy keycloak:8080
}

worldcliques.org {
	encode zstd gzip

	# /login without trailing slash makes browsers resolve css/ and js/ at site root — force /login/
	@login_no_slash path /login
	redir @login_no_slash /login/ 308

	# Globe-landing under /login (strip prefix for upstream)
	handle /login/* {
		uri strip_prefix /login
		reverse_proxy globe-landing:8080
	}
	handle /login/ {
		uri strip_prefix /login
		reverse_proxy globe-landing:8080
	}

	handle {
		reverse_proxy default-html:8080
	}
}
