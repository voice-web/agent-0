# Reference routing for oci-vm (host + path). Regenerated by scripts/up.sh when you run infra.
# HTML vhosts: explicit names only (no *.worldcliques.org). Override with WC_OCI_HTML_HOSTS.
# /login -> globe-landing only when globe-landing is enabled in configs/oci-vm.json.

api.worldcliques.org {
	encode zstd gzip
	reverse_proxy default-api-json:8080
}

auth.worldcliques.org {
	encode zstd gzip
	reverse_proxy keycloak:8080
}

worldcliques.org {
	encode zstd gzip
	handle {
		reverse_proxy default-html:8080
	}
}
