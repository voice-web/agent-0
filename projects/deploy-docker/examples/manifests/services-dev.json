{
  "schema_version": "1.0",
  "set_name": "services-dev",
  "logical_services": [
    {
      "name": "default-html",
      "image": { "ref": "local/default-html:0.0.2" },
      "runtime": {
        "ports": [{ "container": 8080, "published": null }],
        "env": {
          "BASIC_HTTP_ROOT": "/srv/www",
          "PORT": "8080"
        },
        "mounts": [],
        "healthcheck": { "path": "/health", "port": 8080 }
      },
      "capabilities": { "kind": "web-html", "websocket": "not_applicable" }
    },
    {
      "name": "default-api-json",
      "image": { "ref": "local/default-api-json:0.0.1" },
      "runtime": {
        "ports": [{ "container": 8080, "published": null }],
        "env": {
          "PORT": "8080",
          "CORS_ALLOW_ORIGINS": "https://worldcliques.org",
          "CORS_ALLOW_HEADERS": "Authorization,Content-Type"
        },
        "mounts": [],
        "healthcheck": { "path": "/health", "port": 8080 }
      },
      "capabilities": { "kind": "api-json", "websocket": "maybe" }
    }
  ]
}

