{
  "schema_version": "1.0",
  "set_name": "infra",
  "logical_services": [
    {
      "name": "caddy",
      "image": { "ref": "local/caddy:2.8.4" },
      "runtime": {
        "ports": [{ "container": 80, "published": 80 }],
        "env": {},
        "mounts": [
          { "type": "bind", "src": "./routing/Caddyfile-dev", "dst": "/etc/caddy/Caddyfile", "mode": "ro" }
        ],
        "healthcheck": { "path": "/health", "port": 80 }
      },
      "capabilities": { "kind": "ingress", "websocket": "supported" }
    },
    {
      "name": "keycloak",
      "image": { "ref": "local/keycloak:26.0.5" },
      "runtime": {
        "ports": [{ "container": 8080, "published": null }],
        "env": {
          "KEYCLOAK_ADMIN": "{{secrets.KEYCLOAK_ADMIN}}",
          "KEYCLOAK_ADMIN_PASSWORD": "{{secrets.KEYCLOAK_ADMIN_PASSWORD}}"
        },
        "mounts": [],
        "healthcheck": { "path": "/realms/master", "port": 8080 }
      },
      "capabilities": { "kind": "identity", "websocket": "not_applicable" }
    }
  ]
}

