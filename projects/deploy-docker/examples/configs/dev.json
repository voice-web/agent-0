{
  "schema_version": "1.0",
  "env_name": "dev",
  "service_overrides": {
    "default-html": {
      "mounts": [
        { "type": "bind", "src": "{{GLOBE_LANDING_ASSETS}}", "dst": "/srv/www/assets", "mode": "ro" }
      ],
      "env": {}
    },
    "default-api-json": {
      "env": {
        "CORS_ALLOW_ORIGINS": "https://worldcliques.org",
        "CORS_ALLOW_HEADERS": "Authorization,Content-Type"
      },
      "mounts": []
    },
    "keycloak": {
      "env": {
        "KC_HTTP_RELATIVE_PATH": "/auth",
        "KC_PROXY": "edge"
      },
      "mounts": []
    },
    "caddy": {
      "env": {}
    }
  }
}

