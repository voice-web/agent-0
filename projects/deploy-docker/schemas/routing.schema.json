{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldcliques.dev/deploy-docker/routing.schema.json",
  "title": "Routing IR (Caddy v1)",
  "type": "object",
  "required": ["schema_version", "mode"],
  "properties": {
    "schema_version": { "type": "string" },
    "mode": { "enum": ["local_path", "vm_host", "local_ports"] },
    "service_ports": {
      "type": "object",
      "description": "For local_ports: logical service name → host port (Caddy publishes one listener per port).",
      "additionalProperties": { "type": "integer", "minimum": 1, "maximum": 65535 }
    },
    "html_hosts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "For vm_host: hostnames for default-html (no wildcards)"
    }
  },
  "additionalProperties": true
}
