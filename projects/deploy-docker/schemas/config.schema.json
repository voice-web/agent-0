{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldcliques.dev/deploy-docker/config.schema.json",
  "title": "Environment config overlay",
  "type": "object",
  "required": ["schema_version"],
  "properties": {
    "schema_version": { "type": "string" },
    "env_name": { "type": "string" },
    "service_overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": { "enabled": { "type": "boolean" } },
        "additionalProperties": true
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "html_hosts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
