# Copy to `.env` in this directory (same folder as docker-compose.yml).
# Docker Compose loads `.env` automatically; it is gitignored at the repo root.
#
# --- Headless admin (recommended for POC) ---
# On a **fresh** install (no users in the database yet), Open WebUI creates this
# admin at startup. Your login persists in the Docker volume `local-ai_open-webui`
# until you remove the volume (`docker compose down -v` or `docker volume rm …`).
#
# If users already exist, these variables are ignored (no duplicate admin).
#
WEBUI_ADMIN_EMAIL=admin@local.webui
WEBUI_ADMIN_PASSWORD=change-me-to-something-strong
WEBUI_ADMIN_NAME=Admin
